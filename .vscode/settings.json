{
  "editor.defaultFormatter": "biomejs.biome",
  "editor.formatOnSave": true,
  "editor.codeActionsOnSave": {
    "source.fixAll.biome": "explicit",
    "source.organizeImports.biome": "explicit"
  },
  "[javascript]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[javascriptreact]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[typescript]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[json]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[jsonc]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "cSpell.words": [
    "cellspacing",
    "Contáctanos",
    "Dreamlight",
    "Encuéntrate",
    "Español",
    "geist",
    "iban",
    "ilike",
    "lightbox",
    "picdemi",
    "Segoe",
    "serverside",
    "shadcn",
    "supabase",
    "uncategorized",
    "untagging",
    "upserted",
    "upserting",
    "watermarked",
    "yarl"
  ]
}
